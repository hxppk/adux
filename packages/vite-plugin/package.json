{
  "name": "@adux/vite-plugin",
  "version": "0.1.0-rc.0",
  "description": "Vite plugin that injects @adux/runtime into dev-mode apps",
  "license": "MIT",
  "author": "ADUX contributors",
  "homepage": "https://github.com/hxppk/adux#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/hxppk/adux.git",
    "directory": "packages/vite-plugin"
  },
  "bugs": {
    "url": "https://github.com/hxppk/adux/issues"
  },
  "keywords": [
    "adux",
    "antd",
    "vite",
    "plugin",
    "runtime",
    "overlay"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "tag": "rc"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "vite": ">=5.0.0"
  },
  "dependencies": {
    "@adux/runtime": "workspace:*",
    "launch-editor": "^2.13.2"
  },
  "devDependencies": {
    "vite": "^8.0.10"
  }
}
