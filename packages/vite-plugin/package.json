{
  "name": "@adux/vite-plugin",
  "version": "0.0.1",
  "description": "Vite plugin that injects @adux/runtime into dev-mode apps",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "vite": ">=5.0.0"
  },
  "dependencies": {
    "@adux/runtime": "workspace:*",
    "launch-editor": "^2.13.2"
  },
  "devDependencies": {
    "vite": "^8.0.10"
  }
}
