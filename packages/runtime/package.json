{
  "name": "@adux/runtime",
  "version": "0.1.0-rc.0",
  "description": "ADUX browser runtime — overlay violations on real UI (Shadow DOM + Canvas + Preact)",
  "license": "MIT",
  "author": "ADUX contributors",
  "homepage": "https://github.com/hxppk/adux#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/hxppk/adux.git",
    "directory": "packages/runtime"
  },
  "bugs": {
    "url": "https://github.com/hxppk/adux/issues"
  },
  "keywords": [
    "adux",
    "antd",
    "design-system",
    "runtime",
    "overlay",
    "react"
  ],
  "type": "module",
  "main": "./dist/index.js",
