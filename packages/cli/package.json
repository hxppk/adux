{
  "name": "@adux/cli",
  "version": "0.1.0-rc.0",
  "description": "ADUX command-line interface",
  "license": "MIT",
  "author": "ADUX contributors",
  "homepage": "https://github.com/hxppk/adux#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/hxppk/adux.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/hxppk/adux/issues"
  },
  "keywords": [
    "adux",
    "antd",
    "design-system",
    "lint",
    "cli",
    "review"
  ],
  "type": "module",
  "bin": {
    "adux": "./dist/bin.js"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "tag": "rc"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@babel/parser": "^7.25.0",
    "@babel/traverse": "^7.25.0",
    "@babel/types": "^7.25.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "cac": "^6.7.14",
    "fast-glob": "^3.3.3",
    "kleur": "^4.1.5"
  },
  "devDependencies": {
    "@adux/core": "workspace:*"
  }
}
