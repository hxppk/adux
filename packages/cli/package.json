{
  "name": "@adux/cli",
  "version": "0.0.4-alpha.0",
  "description": "ADUX command-line interface",
  "type": "module",
  "bin": {
    "adux": "./dist/bin.js"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "tag": "alpha"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@babel/parser": "^7.25.0",
    "@babel/traverse": "^7.25.0",
    "@babel/types": "^7.25.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "cac": "^6.7.14",
    "fast-glob": "^3.3.3",
    "kleur": "^4.1.5"
  },
  "devDependencies": {
    "@adux/core": "workspace:*"
  }
}
